{
  "name": "graph-coverage-metrics",
  "version": "0.1.0",
  "description": "Interactive educational tool for graph coverage metrics analysis",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .js,.ts,.svelte",
    "lint:fix": "eslint . --ext .js,.ts,.svelte --fix",
    "format": "prettier --write .",
    "check": "pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "cytoscape": "^3.26.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/dom": "^9.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.38.0",
    "eslint-plugin-svelte": "^2.34.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "terser": "^5.46.1",
    "tslib": "^2.6.0",
    "typescript": "^5.2.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "cookie": ">=0.7.0"
    }
  }
}
